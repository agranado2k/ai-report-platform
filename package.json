{
  "name": "centaur-spec",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "packageManager": "pnpm@10.5.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "typecheck": "turbo typecheck",
    "lint": "biome ci .",
    "format": "biome check --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "e2e:gen": "bddgen",
    "e2e": "bddgen && playwright test",
    "clean": "turbo clean && rm -rf node_modules",
    "docs:check": "node scripts/docs-conformance/index.mjs",
    "docs:check:test": "node --test scripts/docs-conformance/test/*.test.mjs",
    "prepare": "husky || true",
    "commitlint": "commitlint --edit",
    "release": "semantic-release",
    "release:dry": "semantic-release --dry-run --no-ci"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "@clerk/testing": "^2.2.5",
    "@commitlint/cli": "^19.6.0",
    "@commitlint/config-conventional": "^19.6.0",
    "@playwright/test": "^1.60.0",
    "@semantic-release/commit-analyzer": "^13.0.0",
    "@semantic-release/github": "^11.0.1",
    "@semantic-release/release-notes-generator": "^14.0.1",
    "conventional-changelog-conventionalcommits": "^8.0.0",
    "husky": "^9.1.7",
    "playwright-bdd": "^9.0.0",
    "semantic-release": "^24.2.0",
    "turbo": "^2.5.0",
    "typescript": "^5.6.3",
    "vitest": "^3.2.4"
  }
}
