{
  "name": "arp-mcp",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "sideEffects": false,
  "scripts": {
    "build": "esbuild src/index.ts --bundle --platform=node --format=esm --packages=external --outfile=dist/server.mjs",
    "dev": "esbuild src/local.ts --bundle --platform=node --format=esm --packages=external --outfile=dist/local.mjs && node dist/local.mjs",
    "typecheck": "tsc"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.26.0",
    "express": "^5.1.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.0",
    "esbuild": "^0.21.5",
    "typescript": "^5.6.3"
  },
  "engines": {
    "node": ">=20"
  }
}
